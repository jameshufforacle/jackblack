{
  "appName": "JackBlack",
  "baseUrl": "https://jackblack-ten.vercel.app",
  "auth": {
    "required": false,
    "loginPath": "",
    "username": "",
    "password": "",
    "usernameSelector": "",
    "passwordSelector": "",
    "submitSelector": "",
    "successUrlPattern": "",
    "successText": []
  },
  "globalRules": {
    "maxStepTimeSeconds": 45,
    "waitForNetworkIdle": false,
    "notes": [
      "Public static Vercel demo. Open directly; no credentials are used.",
      "If the interactive app shell is slow in the judging browser, first verify /judge. It is a same-origin static proof page with no JavaScript or redirects.",
      "Default seeded hand in the app is deterministic: player hard 16 against dealer 10, with Surrender recommended at EV -0.500.",
      "Repository evidence is available at https://github.com/jameshufforacle/jackblack."
    ]
  },
  "workflows": [
    {
      "id": "public-demo-proof",
      "name": "Verify public judge-safe proof path",
      "purpose": "Confirms the submitted demo origin opens directly before testing the interactive app.",
      "startPath": "/judge",
      "steps": [
        {
          "action": "goto",
          "value": "/judge"
        },
        {
          "action": "assertVisible",
          "selector": "#judge-proof"
        },
        {
          "action": "assertText",
          "selector": "#public-access",
          "value": "Public demo: open directly. No credentials are used."
        },
        {
          "action": "assertText",
          "selector": "#proof-player",
          "value": "Hard 16"
        },
        {
          "action": "assertText",
          "selector": "#proof-dealer",
          "value": "10"
        },
        {
          "action": "assertText",
          "selector": "#proof-action",
          "value": "Surrender"
        },
        {
          "action": "assertText",
          "selector": "#proof-ev",
          "value": "-0.500"
        },
        {
          "action": "assertText",
          "selector": "#proof-outcome",
          "value": "Lost 0.5. Optimal."
        }
      ],
      "success": {
        "requiredUrlPattern": "/judge",
        "allowedUrlPatterns": [
          "/judge"
        ],
        "allText": [
          "JackBlack Judge-Safe Demo Proof",
          "Public demo: open directly. No credentials are used.",
          "Hard 16",
          "10",
          "Surrender",
          "-0.500",
          "Lost 0.5. Optimal."
        ],
        "anyText": [],
        "visibleSelectors": [
          "#judge-proof",
          "#public-access",
          "#proof-action",
          "#proof-ev",
          "#app-link",
          "#repo-link"
        ]
      }
    },
    {
      "id": "interactive-strategy-loop",
      "name": "Verify playable blackjack strategy loop",
      "purpose": "Proves the real app table recommends the mathematically best move and resolves the deterministic hand.",
      "startPath": "/",
      "steps": [
        {
          "action": "goto",
          "value": "/"
        },
        {
          "action": "assertVisible",
          "selector": "main"
        },
        {
          "action": "assertText",
          "selector": "#tableTitle",
          "value": "Captain BlackJack's Table"
        },
        {
          "action": "assertText",
          "selector": "#tableRecommendation",
          "value": "Surrender"
        },
        {
          "action": "assertText",
          "selector": "#tableEv",
          "value": "-0.500"
        },
        {
          "action": "click",
          "selector": "button[data-action=\"surrender\"]"
        },
        {
          "action": "waitForText",
          "value": "Lost 0.5. Optimal."
        },
        {
          "action": "assertText",
          "selector": "#outcomeTitle",
          "value": "Loss"
        },
        {
          "action": "assertText",
          "selector": "#roundState",
          "value": "Lost 0.5. Optimal."
        }
      ],
      "success": {
        "requiredUrlPattern": "",
        "allowedUrlPatterns": [
          "/"
        ],
        "allText": [
          "Captain BlackJack's Table",
          "Surrender",
          "-0.500",
          "Loss",
          "Lost 0.5. Optimal."
        ],
        "anyText": [],
        "visibleSelectors": [
          "#dealerHand",
          "#playerHand",
          "#outcomeBanner",
          "#roundState"
        ]
      }
    },
    {
      "id": "coach-and-rules-proof",
      "name": "Verify coach screen and configurable rules",
      "purpose": "Proves the educational analysis and table-rule configuration are present.",
      "startPath": "/",
      "steps": [
        {
          "action": "goto",
          "value": "/"
        },
        {
          "action": "click",
          "selector": "button[data-screen=\"coach\"]"
        },
        {
          "action": "assertText",
          "selector": "#coachTitle",
          "value": "Best Move Right Now"
        },
        {
          "action": "assertText",
          "selector": "#coachAction",
          "value": "Surrender"
        },
        {
          "action": "assertText",
          "selector": "#coachExplanation",
          "value": "Late surrender trims the loss on a hard 16 against a dealer 10."
        },
        {
          "action": "click",
          "selector": "#settingsButton"
        },
        {
          "action": "assertVisible",
          "selector": "#settingsPanel"
        },
        {
          "action": "assertVisible",
          "selector": "#deckCount"
        },
        {
          "action": "assertVisible",
          "selector": "#blackjackPayout"
        }
      ],
      "success": {
        "requiredUrlPattern": "",
        "allowedUrlPatterns": [
          "/"
        ],
        "allText": [
          "Best Move Right Now",
          "Surrender",
          "Late surrender trims the loss on a hard 16 against a dealer 10.",
          "Table Settings",
          "Decks",
          "Blackjack"
        ],
        "anyText": [],
        "visibleSelectors": [
          "#coachAction",
          "#coachExplanation",
          "#settingsPanel",
          "#deckCount",
          "#blackjackPayout"
        ]
      }
    }
  ],
  "manualReviewTriggers": []
}
